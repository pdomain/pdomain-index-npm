{
  "name": "pdomain-index-npm-tools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Build tooling for the pdomain-index-npm static registry. GitHub Pages hosts generated packuments, while tarballs live in publisher GitHub Releases.",
  "author": "CT <concavetrillion@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pdomain/pdomain-index-npm.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format:check": "prettier --check \"scripts/**/*.{ts,mjs}\" \"tests/**/*.ts\" \".github/workflows/*.{yml,yaml}\" \"*.{json,js}\" \"README.md\" \"CONVENTIONS.md\" \"docs/**/*.md\" \"tests/**/*.md\"",
    "actionlint": "node scripts/actionlint.mjs",
    "shell:check": "bash -n scripts/do-release.sh scripts/release-common.sh tests/smoke/run.sh",
    "static-check": "npm run typecheck && npm run lint && npm run format:check && npm run actionlint && npm run shell:check",
    "ci": "npm run static-check && npm test",
    "regen-index": "npm run build --silent && node dist/scripts/regen-index.js",
    "smoke": "bash tests/smoke/run.sh",
    "test": "npm run build --silent && node --test --test-reporter=spec dist/tests/*.test.js dist/tests/**/*.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "actionlint": "^2.0.6",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
